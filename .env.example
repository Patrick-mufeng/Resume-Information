# ===================================================
#  简历信息提取系统 - 环境配置（模板）
#  复制为 .env 后修改使用
# ===================================================

# ---------- 服务器设置 ----------
# 监听地址，0.0.0.0 表示允许局域网内其他设备访问
HOST=0.0.0.0
# 服务端口号
PORT=8000
# 调试模式，true 开启详细日志（生产环境请设为 false）
DEBUG=true

# ---------- 数据库 ----------
# SQLite 数据库文件路径，默认存放在项目 data 目录下
DATABASE_URL=sqlite+aiosqlite:///./data/resume_processor.db

# ---------- 文件存储 ----------
# 简历图片上传目录
UPLOAD_DIR=./data/uploads
# 单个文件大小上限（MB）
MAX_UPLOAD_SIZE_MB=10

# ---------- API 速率限制（每个 Key 独立计算） ----------
# 每分钟 Token 上限
RATE_LIMIT_TPM=32000
# 每分钟请求次数上限
RATE_LIMIT_RPM=3
# 每天 Token 总上限
RATE_LIMIT_TPD=1500000

# ---------- 处理设置 ----------
# 最大并行处理数（建议不超过 Key 数量）
MAX_CONCURRENT_PROCESSING=3
# 单个文件最大重试次数
RETRY_MAX_ATTEMPTS=3

# ---------- 加密密钥 ----------
# 用于加密存储 API Key，请运行以下命令生成并替换：
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ⚠️ 更换密钥后之前存储的 Key 将无法解密，需重新添加
ENCRYPTION_KEY=change-me-run-generate-command-above

# ---------- Web 访问密码（可选） ----------
# 为空则不启用密码保护，仅限本机使用
# 如需远程访问建议设置密码：WEB_PASSWORD=你的密码
WEB_PASSWORD=
